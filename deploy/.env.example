# ===== 智能简历分析系统 - 环境变量配置 =====

# --- AI API 配置 ---
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# --- 代理（按需，用于访问 AI API） ---
HTTP_PROXY=http://127.0.0.1:7897

# --- Redis 配置（可选，不配置则使用内存缓存） ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- 阿里云函数计算 FC 配置 ---
FC_REGION=cn-hangzhou
FC_SERVICE_NAME=resume-analyzer
FC_FUNCTION_NAME=resume-api

# --- CORS 允许的前端来源（逗号分隔） ---
CORS_ORIGINS=https://your-username.github.io,http://localhost:5500
