#!/bin/bash
# 阿里云 FC Custom Runtime 启动脚本
# 使用便携式 Python 3.9 + 离线 wheel 包，彻底解决冷启动超时

cd $(dirname $0)

# 便携式 Python 3.9 路径
PYTHON=./portable_python/python/bin/python3.9

# 首次启动时从本地 wheel 包安装依赖（warm start 会跳过）
if ! $PYTHON -c "import uvicorn" 2>/dev/null; then
    echo "Installing dependencies from local wheels/ via portable Python 3.9..."
    $PYTHON -m pip install \
        --no-index \
        --find-links ./wheels \
        -r requirements.txt \
        -q
    echo "Dependencies installed"
fi

echo "Starting uvicorn on port ${FC_SERVER_PORT:-9000}..."
exec $PYTHON -m uvicorn app.main:app \
    --host 0.0.0.0 \
    --port ${FC_SERVER_PORT:-9000} \
    --workers 1 \
    --log-level info
